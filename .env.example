# Firebase Configuration (required)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_FIRESTORE_DATABASE_ID=ai-studio-your-database-id

# OneSignal Configuration (required for push notifications)
VITE_ONESIGNAL_APP_ID=9d1c4b2e-71ad-4511-8073-646a535603a3
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key-here

# Supabase Configuration (if using Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

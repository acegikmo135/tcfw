{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "role": { "type": "string", "enum": ["admin", "resident"], "description": "User's role in the building." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "Notice": {
      "title": "Building Notice",
      "description": "Stores notices posted by admins for residents.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the notice." },
        "content": { "type": "string", "description": "Full content of the notice." },
        "type": { "type": "string", "enum": ["info", "warning", "success"], "description": "Type of notice." },
        "date": { "type": "string", "format": "date-time", "description": "Date and time the notice was posted." },
        "author": { "type": "string", "description": "Name of the person who posted the notice." },
        "authorUid": { "type": "string", "description": "UID of the author." }
      },
      "required": ["title", "content", "type", "date", "author", "authorUid"]
    },
    "Transaction": {
      "title": "Expense/Income Transaction",
      "description": "Stores financial transactions for the building.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the transaction." },
        "amount": { "type": "number", "description": "Amount of the transaction." },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Type of transaction." },
        "category": { "type": "string", "description": "Category (e.g., Maintenance, Utilities)." },
        "date": { "type": "string", "format": "date-time", "description": "Date of the transaction." },
        "status": { "type": "string", "enum": ["completed", "pending"], "description": "Status of the transaction." },
        "description": { "type": "string", "description": "Detailed description." },
        "createdBy": { "type": "string", "description": "Name of the person who created the entry." },
        "creatorUid": { "type": "string", "description": "UID of the creator." }
      },
      "required": ["title", "amount", "type", "category", "date", "status", "creatorUid"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Building notices."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions."
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: flats
    // Document ID: {flatId} (e.g., F601)
    // Fields:
    //   - flatNo: string (required)
    //   - role: string (required, 'admin' or 'resident')
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - type: string (required, 'income' or 'expense')
    //   - amount: number (required, positive)
    //   - category: string (required)
    //   - description: string (optional)
    //   - date: timestamp (required)
    //   - createdBy: string (required, flatId)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == "manthankansagra@gmail.com" || 
         request.auth.token.email.lower() == "f602@building.local" ||
         request.auth.token.email.lower() == "admin@building.local" ||
         (exists(/databases/$(database)/documents/flats/$(request.auth.token.email.split('@')[0].lower())) && 
          get(/databases/$(database)/documents/flats/$(request.auth.token.email.split('@')[0].lower())).data.role == 'admin'));
    }

    // Validation Functions
    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'category', 'date', 'createdBy']) &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() > 0 &&
             data.date is timestamp &&
             data.createdBy is string;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['text', 'createdBy', 'createdAt', 'role']) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdBy is string &&
             data.createdAt is timestamp &&
             data.role in ['admin', 'resident'];
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'content', 'createdBy', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.createdBy is string &&
             data.createdAt is timestamp;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'type']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.type in ['income', 'expense'];
    }

    match /flats/{flatId} {
      allow read: if isAuthenticated();
      // Allow admins to manage all flats
      // Allow initial setup for specific emails, but restrict role creation
      allow create: if isAdmin() || 
        (isAuthenticated() && 
         (request.auth.token.email == flatId + "@building.local" || request.auth.token.email == "manthankansagra@gmail.com") &&
         (request.resource.data.role == 'resident' || request.auth.token.email == 'f602@building.local' || request.auth.token.email == 'manthankansagra@gmail.com')
        );
      allow update: if isAdmin() || 
        (isAuthenticated() && request.auth.token.email.split('@')[0] == flatId && 
         (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
         (!('flatNo' in request.resource.data) || request.resource.data.flatNo == resource.data.flatNo)
        );
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      // All residents can read transactions
      allow read: if isAuthenticated();
      // Only admins can create/update/delete transactions
      allow create: if isAdmin() && isValidTransaction(request.resource.data);
      allow update: if isAdmin() && isValidTransaction(request.resource.data);
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidComment(request.resource.data) && request.resource.data.createdBy == request.auth.token.email.split('@')[0];
        allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.token.email.split('@')[0]);
      }
    }

    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidNotice(request.resource.data);
      allow update: if isAdmin() && isValidNotice(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
